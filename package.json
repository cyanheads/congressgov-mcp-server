{
  "name": "@cyanheads/congressgov-mcp-server",
  "version": "0.3.6",
  "description": "Access U.S. congressional data - bills, votes, members, committees - through MCP. STDIO & Streamable HTTP.",
  "mcpName": "io.github.cyanheads/congressgov-mcp-server",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "congressgov-mcp-server": "dist/index.js"
  },
  "files": ["dist/", "README.md", "LICENSE", "CLAUDE.md", "Dockerfile", "server.json"],
  "scripts": {
    "build": "bun scripts/build.ts",
    "rebuild": "bun scripts/clean.ts && bun scripts/build.ts",
    "clean": "bun scripts/clean.ts",
    "devcheck": "bun scripts/devcheck.ts",
    "tree": "bun scripts/tree.ts",
    "format": "biome check --write --unsafe .",
    "lint:mcp": "bun scripts/lint-mcp.ts",
    "test": "vitest run",
    "dev:stdio": "MCP_TRANSPORT_TYPE=stdio bun --watch src/index.ts",
    "dev:http": "MCP_TRANSPORT_TYPE=http bun --watch src/index.ts",
    "start:stdio": "MCP_TRANSPORT_TYPE=stdio node dist/index.js",
    "start:http": "MCP_TRANSPORT_TYPE=http node dist/index.js"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "congress",
    "congress-gov",
    "legislation",
    "bills",
    "legislative-data",
    "typescript",
    "us-government"
  ],
  "author": "Casey Hand <casey@cyanheads.dev> (https://github.com/cyanheads)",
  "homepage": "https://github.com/cyanheads/congressgov-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/cyanheads/congressgov-mcp-server/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cyanheads/congressgov-mcp-server.git"
  },
  "license": "Apache-2.0",
  "packageManager": "bun@1.3.2",
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.2.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@cyanheads/mcp-ts-core": "^0.2.8",
    "pino-pretty": "^13.1.3"
  },
  "overrides": {
    "brace-expansion": ">=2.0.3",
    "path-to-regexp": ">=8.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/node": "^25.5.0",
    "depcheck": "^1.4.7",
    "ignore": "^7.0.5",
    "tsc-alias": "^1.8.16",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
